              "type": "string",
              "value": "={{ ($json.phoneUnformatted || $json.phone || '').toString().trim() }}"
            },
            {
              "id": "cd-website",
              "name": "website",
              "type": "string",
              "value": "={{ $json.website ? ($json.website.toString().trim().match(/^https?:\\/\\//i) ? $json.website.toString().trim() : 'https://' + $json.website.toString().trim()) : '' }}"
            },
            {
              "id": "cd-address",
              "name": "address",
              "type": "string",
              "value": "={{ ($json.address || '').toString().trim() }}"
            },
            {
