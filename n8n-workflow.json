              "value": "={{ ($json.city || '').toString().trim() }}"
            },
            {
              "id": "cd-category",
              "name": "categoryName",
              "type": "string",
              "value": "={{ $json.categoryName || (Array.isArray($json.categories) ? $json.categories.join(', ') : '') }}"
            },
            {
              "id": "cd-reviews",
              "name": "reviewsCount",
              "type": "number",
              "value": "={{ Number($json.reviewsCount) || 0 }}"
            }
          ]
        },
