    {
      "parameters": {
        "jsCode": "const body = $json.body || {};\n\nconst locationQuery = body.locationQuery || [\"Ontario, Canada\"];\nconst maxLeads = Number(body.maxLeads || 5);\nconst searchStringsArray = body.searchStringsArray || [\"HVAC contractor\"];\n\nreturn [{\n  json: {\n    locationQuery: Array.isArray(locationQuery) ? locationQuery : [locationQuery],\n    maxLeads,\n    searchStringsArray\n  }\n}];"
      },
      "id": "17ca3fdd-6e59-4268-801e-81cb5c30224f",
      "name": "Validate & Normalize Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1008, 112]
    },
    {
      "parameters": {
        "url": "=https://api.apify.com/v2/acts/{{ $('Webhook - Lead Gen').item.json.body.workflowConfig.apify.actor || 'compass~google-maps-extractor' }}/run-sync-get-dataset-items",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Webhook - Lead Gen').item.json.body.workflowConfig.apify.token }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  includeWebResults: false,\n  language: $('Webhook - Lead Gen').item.json.body.workflowConfig.apify.language || \"en\",\n  locationQuery:$json.locationQuery[0] ,\n  maxCrawledPlacesPerSearch: $('Webhook - Lead Gen').item.json.body.workflowConfig.apify.maxCrawledPlacesPerSearch || $json.maxLeads,\n  maxImages: 0,\n  maximumLeadsEnrichmentRecords: 0,\n  scrapeContacts: false,\n  scrapeDirectories: false,\n  scrapeImageAuthors: false,\n  scrapePlaceDetailPage: false,\n  scrapeReviewsPersonalData: false,\n  scrapeTableReservationProvider: false,\n  searchStringsArray: $json.searchStringsArray,\n  skipClosedPlaces: true\n} }}",
        "options": {}
      },
      "id": "fc7e2691-d4ec-4500-a6d6-3462e494874c",
